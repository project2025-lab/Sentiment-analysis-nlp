"source": [
"# Install if not already available\n",
"!pip install -q nltk scikit-learn\n",
"\n",
"# Imports\n",
"import nltk\n",
"nltk.download('movie_reviews')\n",
"import random\n",
"from nltk.corpus import movie_reviews\n",
"from sklearn.feature_extraction.text import CountVectorizer\n",
"from sklearn.naive_bayes import MultinomialNB\n",
"from sklearn.model_selection import train_test_split\n",
"from sklearn.metrics import accuracy_score, classification_report"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {
"id": "n9lE8bwCWiFu"
},
"outputs": [],
"source": [
"# Load movie review documents and labels\n",
"documents = [(movie_reviews.raw(fileid), category)\n",
"             for category in movie_reviews.categories()\n",
"             for fileid in movie_reviews.fileids(category)]\n",
"random.shuffle(documents)\n",
"\n",
"# Split into texts and labels\n",
"texts = [review for review, label in documents]\n",
"labels = [label for review, label in documents]"
]
},
{
"cell_type": "code",
"execution_count": null,
"metadata": {
"id": "76BHDEGRWkLW"
},
"outputs": [],
"source": [
"# Convert text data to bag-of-words feature vectors\n",
"vectorizer = CountVectorizer(stop_words='english')\n",
"X = vectorizer.fit_transform(texts)\n",
"y = labels"
]
},
